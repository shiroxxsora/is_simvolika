# =============================================================================
# НАСТРОЙКИ РАЗВЕРТЫВАНИЯ — скопируйте в docker/.env и заполните перед запуском
#
# Linux/macOS:  cp docker/.env.example docker/.env
# Windows:      copy docker\.env.example docker\.env
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# Поменяйте POSTGRES_PASSWORD на надёжный пароль.
# POSTGRES_DSN должен совпадать с USER / PASSWORD / DB ниже.
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rag
POSTGRES_DSN=postgresql://postgres:postgres@postgres:5432/rag

# -----------------------------------------------------------------------------
# Telegram-бот
# Получите токен у @BotFather в Telegram.
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# =============================================================================
# LLM — языковая модель (RAG-ответы и анализ изображений)
# =============================================================================

# Вариант A: LM Studio на хосте (по умолчанию)
#   - откройте LM Studio → Local Server → Start Server (порт 1234)
#   - загрузите модель (рекомендуется qwen3.5-9b или аналог)
#   - в настройках модели установите Context Length ≥ 8192
#   - LM Studio должен быть запущен ДО docker compose up
LLM_API_URL=http://host.docker.internal:1234/v1/chat/completions
LLM_API_KEY=
LLM_MODEL=qwen/qwen3.5-9b
VISION_MODEL=qwen/qwen3.5-9b

# Вариант B: OpenAI API (закомментируйте Вариант A, раскомментируйте ниже)
# LLM_API_URL=https://api.openai.com/v1/chat/completions
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# VISION_MODEL=gpt-4o-mini

# =============================================================================
# VL-модель для OCR / подготовки документов (prepare_docs)
# Берётся из env: PREPARE_VL_API_URL, PREPARE_VL_MODEL, PREPARE_VL_ZOOM, PREPARE_PAGE_ENGINE
# =============================================================================
PREPARE_VL_API_URL=http://host.docker.internal:1234/v1/chat/completions
PREPARE_VL_MODEL=qwen/qwen3.5-9b
PREPARE_VL_ZOOM=3
PREPARE_PAGE_ENGINE=vl
PREPARE_VL_TIMEOUT=6000

# =============================================================================
# Эмбеддинги (текст)
# =============================================================================

# Вариант A: LM Studio (загрузите embedding-модель, например text-embedding-qwen3-embedding-8b)
EMBEDDING_API_URL=http://host.docker.internal:1234/v1/embeddings
EMBEDDING_MODEL=text-embedding-qwen3-embedding-8b
# Не менять без миграции БД (Liquibase 006) и полной переиндексации
EMBEDDING_DIM=4096

# Вариант B: OpenAI
# EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIM=1536

# Таймаут эмбеддингов (сек). При CPU-инференсе увеличьте до 300–1800
EMBEDDING_TIMEOUT_SEC=300

# =============================================================================
# Эмбеддинги изображений (мультимодальный поиск)
# MULTIMODAL_ENABLED=false — отключает поиск по картинкам (безопаснее при LM Studio)
# =============================================================================
MULTIMODAL_ENABLED=false
IMAGE_EMBEDDING_API_URL=
IMAGE_EMBEDDING_MODEL=qwen.qwen3-vl-embedding-2b
IMAGE_EMBEDDING_DIM=1024
IMAGE_EMBEDDING_TIMEOUT_SEC=240

# =============================================================================
# RAG — параметры поиска и индексации (менять не нужно при стандартном деплое)
# =============================================================================
RAG_PDF_ROOT=/app/docs
RAG_DOCS_DIR=/app/docs_prepared
RAG_TOC_DIR=/app/docs_toc
RAG_TOP_K=3
RAG_MAX_DISTANCE=0.38
RAG_IMAGE_MAX_DISTANCE=0.55
RAG_FALLBACK_ON_EMPTY=true
RAG_FALLBACK_MAX_DISTANCE=0.52
RAG_CHUNK_SIZE=2000
RAG_CHUNK_OVERLAP=320
RERANK_VECTOR_WEIGHT=0.75
RERANK_LEXICAL_WEIGHT=0.25
RERANK_MIN_LEXICAL_OVERLAP=0.015
RERANK_MIN_LEXICAL_OVERLAP_IMAGE=0.0

# =============================================================================
# Tesseract OCR (fallback при ошибке VL; язык пакетов)
# =============================================================================
TESSERACT_LANG=rus+eng

# =============================================================================
# Внутренние адреса (не менять)
# =============================================================================
RAG_URL=http://rag:8000
